{
  "name": "claude-companion",
  "version": "0.11.2",
  "description": "Chat with Claude inside your Obsidian vault, generate beautiful interactive artifacts, and sync them back into your notes.",
  "main": "main.js",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cavi-ai/claude-obsidian.git",
    "directory": "obsidian-plugin"
  },
  "bugs": {
    "url": "https://github.com/cavi-ai/claude-obsidian/issues"
  },
  "homepage": "https://github.com/cavi-ai/claude-obsidian/tree/main/obsidian-plugin#readme",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint": "eslint src",
    "audit": "pnpm dlx pnpm@11.7.0 --pm-on-fail=ignore audit --prod --audit-level high",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:research": "pnpm run build && playwright test --config=e2e/playwright.config.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "sharp": "^0.35.3",
      "adm-zip": "^0.6.0"
    }
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "claude",
    "anthropic",
    "ai"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "esbuild": "0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "globals": "^17.7.0",
    "linkedom": "^0.18.13",
    "obsidian": "^1.13.0",
    "tslib": "^2.6.3",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "defuddle": "^0.19.1"
  }
}
